# LLM provider (required for LLM-powered classification & answer synthesis)
GROQ_API_KEY=your_groq_api_key_here

# Live AQI data (optional — agent falls back to static DPCC/PIB docs if unset)
# Get a free token at https://aqicn.org/api/
WAQI_API_TOKEN=your_waqi_api_token_here

# Elasticsearch (optional — falls back to Chroma if unset)
# For local ES (docker-compose up):
ES_URL=http://localhost:9200
# For Elastic Cloud:
# ES_URL=https://your-deployment.es.us-east-1.aws.cloud.es.io:443
# ES_API_KEY=your_api_key_here
